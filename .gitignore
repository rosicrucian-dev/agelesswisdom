# Dependencies
/node_modules

# Next.js build output
/.next/
/.next-verify/
/out/

# Source material: purchased books and their OCR output live locally only.
# The extraction script (scripts/extract.ts) reads ./ocr; the curated MDX
# it produces under src/data/lessons/ IS committed.
/books/
/ocr/

# Editorial workspace — the ENTIRE adjudication apparatus lives here, fully
# local and NEVER committed: donor masters (with the B.O.T.A. header lines to
# strip), the conversion build/, per-lesson change ledgers, the publication
# denylist, the source-fidelity baseline, the pipeline scripts, and the
# editorial records (reprint-typo catalog, migration plan). One rule, one
# thing to reason about. See editorial/README.md.
/editorial/

# Vendored template kits, kept for reference only
/catalyst-ui-kit/
/tailwind-plus-compass/

# Local-only tooling: the figure re-cropping tool stays on disk, out of the repo.
/scripts/recrop/

# Defence-in-depth: even if an editorial artifact is written under content/ by
# mistake, it can never be staged. Only lesson .mdx belongs in content/.
/content/**/*.changes.json
/content/excluded-lessons.json
/content/source-fidelity.baseline.json
/content/README.md

# Local AI-assistant guidance
CLAUDE.md
.claude/

# Misc
.DS_Store
*.pem
npm-debug.log*
.env*
*.tsbuildinfo
next-env.d.ts

# Working notes — local-only. Editorial records live under
# /editorial/records/; nothing in docs/ is committed.
/docs/

# Generated by scripts/gen-search-index.ts on every build
/public/search-index.json

# Generated print/PDF artifacts
/output/
/tmp/
# Per-lesson PDFs are derived from the MDX and regenerated at deploy time
# (scripts/print/lessons.ts, run by the Deploy workflow before `next build`);
# never committed. Run `npm run pdf:lessons` locally to preview them.
/public/lessons/
